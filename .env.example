# 前端：当主站部署在 GitHub Pages 时，用这个变量指向承接真实模型的 Vercel 域名
# 例子：VITE_JOBS_CHAT_API_BASE_URL=https://liutongxue-web.vercel.app
VITE_JOBS_CHAT_API_BASE_URL=

# 后端：Vercel / 本地 API 所需的真实模型配置（OpenAI 兼容接口）
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
OPENAI_BASE_URL=https://api.openai.com/v1

# 允许跨域调用 API 的前端来源，多个地址用英文逗号分隔
# 例子：ALLOWED_ORIGINS=https://dosliu.github.io,https://liutongxue-web.vercel.app,http://localhost:5173
ALLOWED_ORIGINS=
