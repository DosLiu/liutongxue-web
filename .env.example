# 前端：正式部署默认走 https://www.liutongxue.com.cn 同域 /api/chat，通常不需要配置这个变量
# 只有当前端临时部署在其他域名时，才显式指定 API 基地址
# 例子：VITE_JOBS_CHAT_API_BASE_URL=https://www.liutongxue.com.cn
VITE_JOBS_CHAT_API_BASE_URL=

# 前端：特殊调试场景下可直接指定完整 /api/chat 地址；优先级高于 VITE_JOBS_CHAT_API_BASE_URL
# 例子：VITE_CHAT_API_URL=https://www.liutongxue.com.cn/api/chat
VITE_CHAT_API_URL=

# 构建期：canonical / og:url / smoke-check 默认使用的正式站点地址
# 例子：VITE_SITE_URL=https://www.liutongxue.com.cn
VITE_SITE_URL=https://www.liutongxue.com.cn

# 后端：Vercel / 本地 API 所需的真实模型配置（OpenAI 兼容接口）
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
OPENAI_BASE_URL=https://api.openai.com/v1

# 允许跨域调用 API 的前端来源，多个地址用英文逗号分隔
# 例子：ALLOWED_ORIGINS=https://www.liutongxue.com.cn,https://liutongxue.com.cn,http://localhost:5173
ALLOWED_ORIGINS=

# 大恩聚合登录（第一步骨架，先占位，不写真实密钥）
# 登录授权页根地址，例如 https://open.daen.cn
DAEN_AUTH_BASE_URL=
# 登录授权 path；如果第二步确认不是标准 OAuth 路径，再在 auth helper 里统一调整
DAEN_AUTH_AUTHORIZE_PATH=/oauth/authorize
# 第二步接 code -> token 时需要
DAEN_AUTH_TOKEN_URL=
# 第二步换 userinfo / unionid 时需要
DAEN_AUTH_USERINFO_URL=
# 大恩应用 appid / appkey
DAEN_APP_ID=
DAEN_APP_KEY=
# scope 如需调整，在第二步按大恩文档改
DAEN_AUTH_SCOPE=openid profile
# 例子：http://localhost:5173/api/auth/callback 或 https://www.liutongxue.com.cn/api/auth/callback
DAEN_AUTH_CALLBACK_URL=

# session / redirect
# 登录成功后回站地址，当前 callback 会重定向到这里并带 auth=callback-ready
AUTH_LOGIN_SUCCESS_URL=/
# 退出登录后回站地址
AUTH_LOGOUT_REDIRECT_URL=/
AUTH_SESSION_COOKIE_NAME=liutongxue_session
AUTH_STATE_COOKIE_NAME=liutongxue_auth_state
# 至少 32 位随机字符串；当前第一步用它来签名 state / session cookie
AUTH_SESSION_SECRET=
AUTH_SESSION_TTL_SECONDS=604800

# KV 预留（第二步决定是否启用）
AUTH_KV_ENABLED=false
KV_REST_API_URL=
KV_REST_API_TOKEN=
KV_URL=
