# 前端：如果站点和 API 同域部署在 Vercel / 自定义域名下，通常不需要配置这个变量
# 只有当前端部署在其他域名时，才显式指定 API 地址
# 例子：VITE_JOBS_CHAT_API_BASE_URL=https://liutongxue.com.cn
VITE_JOBS_CHAT_API_BASE_URL=

# 后端：Vercel / 本地 API 所需的真实模型配置（OpenAI 兼容接口）
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
OPENAI_BASE_URL=https://api.openai.com/v1

# 允许跨域调用 API 的前端来源，多个地址用英文逗号分隔
# 例子：ALLOWED_ORIGINS=https://liutongxue.com.cn,https://www.liutongxue.com.cn,http://localhost:5173
ALLOWED_ORIGINS=
