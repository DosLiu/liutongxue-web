# 前端：正式部署默认走 https://www.liutongxue.com.cn 同域 /api/chat，通常不需要配置这个变量
# 只有当前端临时部署在其他域名时，才显式指定 API 基地址
# 例子：VITE_JOBS_CHAT_API_BASE_URL=https://www.liutongxue.com.cn
VITE_JOBS_CHAT_API_BASE_URL=

# 前端：特殊调试场景下可直接指定完整 /api/chat 地址；优先级高于 VITE_JOBS_CHAT_API_BASE_URL
# 例子：VITE_CHAT_API_URL=https://www.liutongxue.com.cn/api/chat
VITE_CHAT_API_URL=

# 构建期：canonical / og:url / smoke-check 默认使用的正式站点地址
# 例子：VITE_SITE_URL=https://www.liutongxue.com.cn
VITE_SITE_URL=https://www.liutongxue.com.cn

# 后端：Vercel / 本地 API 所需的真实模型配置（OpenAI 兼容接口）
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
OPENAI_BASE_URL=https://api.openai.com/v1

# 允许跨域调用 API 的前端来源，多个地址用英文逗号分隔
# 例子：ALLOWED_ORIGINS=https://www.liutongxue.com.cn,https://liutongxue.com.cn,http://localhost:5173
ALLOWED_ORIGINS=

# 大恩聚合登录（第二步开始按真实协议接入）
# 文档里的统一接口地址，默认就是大恩 connect.php
DAEN_CONNECT_URL=https://u.daenwl.com/connect.php
# 当前准备开放的登录方式，多个用英文逗号分隔
DAEN_ENABLED_TYPES=qq,baidu
# 大恩应用 appid / appkey（真实值请只放环境变量，不要提交进仓库）
DAEN_APP_ID=
DAEN_APP_KEY=
# 当前会自动把这里的 origin 规范到 /api/daen?route=callback
# 例子：https://www.liutongxue.com.cn/api/daen?route=callback
DAEN_AUTH_CALLBACK_URL=

# session / redirect
# 登录成功后默认回到人物选择页；如果从具体人物页发起登录，会优先回跳原页面
AUTH_LOGIN_SUCCESS_URL=/figures/
# 退出登录后回站地址
AUTH_LOGOUT_REDIRECT_URL=/figures/
AUTH_SESSION_COOKIE_NAME=liutongxue_session
AUTH_STATE_COOKIE_NAME=liutongxue_auth_state
# 至少 32 位随机字符串；当前用它签名 state / session cookie
AUTH_SESSION_SECRET=
AUTH_SESSION_TTL_SECONDS=604800
# 启用 KV 后的人物对话默认每日限额
AUTH_DAILY_LIMIT=10

# KV 预留（第三步继续接“每日 10 次”）
AUTH_KV_ENABLED=false
KV_REST_API_URL=
KV_REST_API_TOKEN=
KV_URL=
