{
  "redirects": [
    {
      "source": "/tools",
      "destination": "/scene/",
      "permanent": true
    },
    {
      "source": "/tools/",
      "destination": "/scene/",
      "permanent": true
    },
    {
      "source": "/tools/:path*",
      "destination": "/scene/",
      "permanent": true
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "has": [
        {
          "type": "host",
          "value": "test.liutongxue.com.cn"
        }
      ],
      "headers": [
        {
          "key": "X-Robots-Tag",
          "value": "noindex, nofollow, noarchive, nosnippet, noimageindex"
        }
      ]
    }
  ]
}
